# Phantom Pipeline — Environment Variables
# Copy this file to .env and customize as needed.
# These are loaded automatically at startup via python-dotenv.

# Execution provider: cpu, cuda, rocm, dml
EXECUTION_PROVIDER=cuda

# WebSocket API server port
API_PORT=9000

# Logging level: debug, info, warning, error
LOG_LEVEL=info

# WebSocket URL for desktop to connect to pipeline
# Local development: ws://localhost:9000/ws
# RunPod remote: wss://<pod-id>-9000.proxy.runpod.net/ws
PHANTOM_API_URL=ws://213.192.2.110:40192/ws
