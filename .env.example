# Phantom Pipeline — Environment Variables
# Copy this file to .env and customize as needed.
# These are loaded automatically at startup via python-dotenv.

# Execution provider: cpu, cuda, rocm, dml
EXECUTION_PROVIDER=cuda

# WebSocket API server port
API_PORT=9000

# Logging level: debug, info, warning, error
LOG_LEVEL=info

# WebSocket URL for desktop to connect to pipeline
# Local development: ws://localhost:9000/ws
# RunPod remote: set automatically by runpod/orchestrator.py start
PHANTOM_API_URL=ws://localhost:9000/ws

# RunPod orchestrator — only needed if using runpod/orchestrator.py
# Get your API key: RunPod dashboard → Settings → API Keys
RUNPOD_API_KEY=
# Pod ID — set automatically by orchestrator on first deploy, or paste from dashboard
RUNPOD_POD_ID=

# Deploy mode: ssh (development) or docker (production)
#   ssh:    orchestrator SSHes in, clones repo, installs deps, starts pipeline in tmux
#   docker: pipeline auto-starts from baked Docker image, no SSH needed
RUNPOD_DEPLOY_MODE=ssh

# Pod config — used when deploying a fresh pod (resume unavailable or first run)
# Datacenter must match where your network volume lives (RunPod dashboard → Storage)
RUNPOD_DATACENTER_ID=EU-RO-1
# GPUs tried in order — first one available in RUNPOD_DATACENTER_ID wins
# Use RunPod's exact display names (check dashboard GPU list for your datacenter)
RUNPOD_GPU_TYPES=NVIDIA GeForce RTX 3090,NVIDIA RTX A4000,NVIDIA GeForce RTX 4090
# ssh mode: use a generic RunPod base image (setup happens over SSH)
# docker mode: use your custom image with pipeline baked in
RUNPOD_IMAGE=runpod/pytorch:2.4.0-py3.11-cuda12.4.1-runtime-ubuntu22.04
RUNPOD_CONTAINER_DISK=20
RUNPOD_VOLUME_DISK=20
# Network volume ID — attach existing /workspace so models survive pod recreation
# Find it: RunPod dashboard → Storage → your volume ID
RUNPOD_NETWORK_VOLUME_ID=

# SSH mode only — ignored in docker mode
RUNPOD_SSH_KEY_PATH=~/.ssh/id_ed25519
# Repo URL for auto-cloning on first deploy — include token for private repos
# Public:  https://github.com/khonello/Phantom.git
# Private: https://<token>@github.com/khonello/Phantom.git
RUNPOD_REPO_URL=https://github.com/khonello/Phantom.git
